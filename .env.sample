# ========================================
# TAXI BOOKING WEB APP - Environment Variables
# ========================================
# This is a master reference for all environment variables used in the project.
# Copy the relevant sections to Backend/.env and frontend/.env respectively.

# ========================================
# BACKEND ENVIRONMENT VARIABLES
# Location: Backend/.env
# ========================================

# Server Configuration
PORT=3000

# Database Configuration
# MongoDB connection string
# Local: mongodb://localhost:27017/database_name
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database_name
DB_CONNECT=mongodb://localhost:27017/taxi-booking-app

# JWT Configuration
# Secret key for JWT token generation and verification
# IMPORTANT: Use a strong, random string in production (minimum 32 characters)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Required APIs to enable:
#   - Geocoding API (for address to coordinates conversion)
#   - Distance Matrix API (for distance and time calculations)
#   - Places API (for autocomplete suggestions)
GOOGLE_MAPS_API=your-google-maps-api-key-here

# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# Location: frontend/.env
# ========================================

# Backend API Configuration
# Base URL for the backend API server
# Development: http://localhost:3000
# Production: https://your-production-api-url.com
VITE_BASE_URL=http://localhost:3000

# IMPORTANT: There's an inconsistency in the codebase
# Some files use VITE_API_URL instead of VITE_BASE_URL
# Set both to the same value to avoid issues
VITE_API_URL=http://localhost:3000

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Required APIs to enable:
#   - Maps JavaScript API (for rendering maps in LiveTracking component)
#   - Places API (for location search and autocomplete)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ========================================
# SETUP INSTRUCTIONS
# ========================================

# 1. Backend Setup:
#    - Copy this file's BACKEND section to Backend/.env
#    - Set up MongoDB (local or Atlas)
#    - Generate a secure JWT_SECRET
#    - Create a Google Maps API key with required APIs enabled
#    - Run: cd Backend && npm install && npm run dev

# 2. Frontend Setup:
#    - Copy this file's FRONTEND section to frontend/.env
#    - Ensure VITE_BASE_URL points to your backend server
#    - Use the same Google Maps API key (or create a separate one with restrictions)
#    - Run: cd frontend && npm install && npm run dev

# 3. Google Maps API Setup:
#    - Visit: https://console.cloud.google.com/
#    - Create a new project or select existing one
#    - Enable the following APIs:
#      * Geocoding API
#      * Distance Matrix API
#      * Places API
#      * Maps JavaScript API
#    - Create credentials (API Key)
#    - Optionally add restrictions (HTTP referrers for frontend, IP addresses for backend)

# 4. MongoDB Setup:
#    Option A - Local MongoDB:
#      - Install MongoDB Community Edition
#      - Start MongoDB service
#      - Use: mongodb://localhost:27017/taxi-booking-app
#    
#    Option B - MongoDB Atlas (Cloud):
#      - Create account at https://www.mongodb.com/cloud/atlas
#      - Create a free cluster
#      - Add your IP to whitelist
#      - Create database user
#      - Get connection string and replace in DB_CONNECT

# ========================================
# SECURITY NOTES
# ========================================

# - NEVER commit .env files to version control
# - Ensure .env is in .gitignore
# - Use different API keys for development and production
# - Rotate JWT_SECRET periodically in production
# - Use environment-specific values (dev/staging/prod)
# - Enable API key restrictions in Google Cloud Console
# - Use MongoDB Atlas IP whitelist in production
# - Consider using a secrets manager for production (AWS Secrets Manager, Azure Key Vault, etc.)

# ========================================
# FOUND INCONSISTENCIES TO FIX
# ========================================

# Frontend files UserLogout.jsx and CaptainLogout.jsx use VITE_API_URL
# while all other files use VITE_BASE_URL. Consider fixing this inconsistency
# by updating these files to use VITE_BASE_URL consistently.
