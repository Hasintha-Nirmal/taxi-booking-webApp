# Server Configuration
PORT=3000

# Database Configuration
# MongoDB connection string
# Format: mongodb://localhost:27017/database_name
# Or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database_name
DB_CONNECT=mongodb://localhost:27017/taxi-booking-app

# JWT Configuration
# Secret key for JWT token generation and verification
# Use a strong, random string in production (minimum 32 characters recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Required APIs to enable:
# - Geocoding API (for address to coordinates conversion)
# - Distance Matrix API (for distance and time calculations)
# - Places API (for autocomplete suggestions)
GOOGLE_MAPS_API=your-google-maps-api-key-here

# CORS Configuration (Optional)
# Uncomment and set if you need to restrict CORS to specific origins
# CORS_ORIGIN=http://localhost:5173

# Node Environment (Optional)
# NODE_ENV=development
